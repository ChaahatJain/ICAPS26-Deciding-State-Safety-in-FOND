# Stage 1: Build
FROM ubuntu:22.04 AS builder

ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=Etc/UTC

RUN apt-get update && apt-get install -y software-properties-common && \
    add-apt-repository ppa:deadsnakes/ppa && \
    apt-get update && \
    apt-get install -y \
        build-essential \
        cmake \
        git \
        python3.8 \
        python3.8-venv \
        python3.8-dev \
        python3.8-distutils \
        wget \
        curl \
        tzdata \
        unzip && \
    rm -rf /var/lib/apt/lists/*

RUN python3.8 -m ensurepip && \
    python3.8 -m pip install --upgrade pip && \
    ln -sf /usr/bin/python3.8 /usr/bin/python3 && \
    ln -sf /usr/bin/pip3.8 /usr/bin/pip3

WORKDIR /workspace
# Copy project source (including gurobi)
COPY . /workspace/dependencies

# Install Gurobi
WORKDIR /workspace/dependencies
RUN wget -v https://packages.gurobi.com/12.0/gurobi12.0.0_linux64.tar.gz \
&& tar -xvf gurobi12.0.0_linux64.tar.gz \
&& rm *.tar.gz && mv -f gurobi1200/ gurobi && mv -f gurobi/linux64/ gurobi/linux
WORKDIR /workspace/dependencies/gurobi/linux/src/build
RUN make && cp libgurobi_c++.a ../../lib

# Set GUROBI_HOME so cmake/make can find it
ENV GUROBI_HOME=/workspace/dependencies/gurobi/linux
ENV PATH=$GUROBI_HOME/bin:$PATH
ENV LD_LIBRARY_PATH=$GUROBI_HOME/lib
ENV PYBIND11_PYTHON_EXECUTABLE=/usr/bin/python3.8

# Build main project
WORKDIR /workspace/dependencies/z3
RUN rm -rf /workspace/dependencies/z3/build && \
mkdir build && \
cd build && \
cmake -DCMAKE_BUILD_TYPE=Release -DZ3_SINGLE_THREADED=True -DPYTHON_EXECUTABLE=/usr/bin/python3.8 .. && \
rm -rf /workspace/dependencies/veritas/manual_build && \
rm -rf /workspace/dependencies/Marabou/build

WORKDIR /workspace/dependencies

RUN set -e && \
    chmod +x install_veritas.sh install_marabou.sh install_torch.sh install_nlohmann.sh && \
    ./install_veritas.sh && \
    ./install_marabou.sh /workspace/dependencies/gurobi/linux && \
    ./install_torch.sh && \
    ./install_nlohmann.sh

# Stage 2: Runtime
# Stage 2: Runtime
FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=Etc/UTC

# Add the same PPA as in builder stage
RUN apt-get update && apt-get install -y software-properties-common && \
    add-apt-repository ppa:deadsnakes/ppa && \
    apt-get update && \
    apt-get install -y \
        python3.8 \
        python3.8-distutils \
        libstdc++6 \
        && rm -rf /var/lib/apt/lists/*

# Create symbolic links for python3
RUN ln -sf /usr/bin/python3.8 /usr/bin/python3

WORKDIR /workspace

# Copy ALL necessary artifacts from builder stage
COPY --from=builder /workspace/ /workspace/
COPY --from=builder /usr/bin/python3.8 /usr/bin/python3.8
COPY --from=builder /usr/lib/python3.8/ /usr/lib/python3.8/
COPY --from=builder /usr/local/ /usr/local/

# Set environment variables for runtime
ENV GUROBI_HOME=/workspace/dependencies/gurobi/linux
ENV PATH=$GUROBI_HOME/bin:/usr/local/bin:$PATH
ENV LD_LIBRARY_PATH=$GUROBI_HOME/lib:/usr/local/lib
ENV PYTHONPATH=/workspace/dependencies/veritas:/workspace/dependencies/Marabou